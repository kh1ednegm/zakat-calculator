# Secret key for signing session cookies. Use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Supabase PostgreSQL connection string (Project Settings -> Database -> Connection string -> URI)
# Replace YOUR_PASSWORD and YOUR_PROJECT_REF. Local default falls back to SQLite.
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# development | production (production enables secure HTTPS-only cookies)
ENV=development
